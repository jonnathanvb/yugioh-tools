@page "/mods"
@using yugiho_tools.Application.Services
@using yugiho_tools.Domain.Entities
@using yugiho_tools.Infrastructure.ModImport
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@inject RemoteCatalogClient Catalog
@inject ModImporter Importer
@inject yugiho_tools.Domain.Interfaces.IModRepository ModRepo
@inject CurrentModContext ModContext
@inject LoadedModCache ModCache
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.False" Class="py-6 px-4"
              Style="max-width:80%; margin-left:auto; margin-right:auto;">

    <div class="d-flex align-center mb-4 gap-2">
        <MudIcon Icon="@Icons.Material.Filled.LibraryBooks"
                 Style="color:#c8a415; font-size:2rem;" />
        <div style="flex:1;">
            <MudText Typo="Typo.overline"
                     Style="color:#888; letter-spacing:2px;">Catálogo</MudText>
            <MudText Typo="Typo.h5" Style="color:#c8a415; font-weight:700;">
                Mods
            </MudText>
        </div>
        <MudTooltip Text="Forçar atualização do catálogo">
            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                           OnClick="RefreshCatalogAsync"
                           Disabled="_loadingCatalog"
                           Style="color:#c8a415;" />
        </MudTooltip>
    </div>

    <MudText Typo="Typo.caption" Style="color:#888;" Class="mb-3 d-block">
        @CatalogStatusText
    </MudText>

    <MudGrid Spacing="3">
        <!-- ─── Catálogo remoto ─────────────────────────────── -->
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;"
                         Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.CloudDownload"
                             Class="mr-1" Size="Size.Small" />
                    Disponíveis para importar
                </MudText>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />

                @if (_loadingCatalog)
                {
                    <div class="d-flex justify-center pa-4">
                        <MudProgressCircular Indeterminate="true" Color="Color.Warning" />
                    </div>
                }
                else if (_catalog.Count == 0)
                {
                    <MudText Typo="Typo.body2" Style="color:#888;" Align="Align.Center">
                        Nenhum mod no catálogo. Confira sua conexão e clique no
                        ícone de atualizar.
                    </MudText>
                }
                else
                {
                    <MudList T="CatalogEntry" Dense="true" Style="background:transparent;">
                        @foreach (var entry in _catalog)
                        {
                            var imported = _imported.Any(m =>
                                string.Equals(m.Slug, ImportSlug(entry), StringComparison.OrdinalIgnoreCase));
                            <MudListItem T="CatalogEntry" Style="border-bottom:1px solid #1f1f4f;">
                                <div class="d-flex align-center gap-2">
                                    <div style="flex:1;">
                                        <MudText Typo="Typo.body1" Style="color:#fff; font-weight:600;">
                                            @entry.Name
                                        </MudText>
                                        <MudText Typo="Typo.caption" Style="color:#888;">
                                            @entry.Date.ToString("yyyy-MM-dd")
                                            @if (imported) { <span style="color:#4caf50;">  · já importado</span> }
                                        </MudText>
                                    </div>
                                    @if (_importing == entry.Id)
                                    {
                                        <div style="min-width:160px;">
                                            <MudProgressLinear Value="@_importPercent"
                                                               Color="Color.Warning" />
                                            <MudText Typo="Typo.caption" Style="color:#888;">
                                                @_importMessage
                                            </MudText>
                                        </div>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Filled"
                                                   Color="@(imported ? Color.Default : Color.Warning)"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Download"
                                                   OnClick="() => ImportAsync(entry)">
                                            @(imported ? "Reimportar" : "Importar")
                                        </MudButton>
                                    }
                                </div>
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudPaper>
        </MudItem>

        <!-- ─── Mods instalados ─────────────────────────────── -->
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;"
                         Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Folder"
                             Class="mr-1" Size="Size.Small" />
                    Instalados
                </MudText>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />

                @if (_imported.Count == 0)
                {
                    <MudText Typo="Typo.body2" Style="color:#888;" Align="Align.Center">
                        Nenhum mod instalado. Importe um da lista ao lado.
                    </MudText>
                }
                else
                {
                    <MudList T="Mod" Dense="true" Style="background:transparent;">
                        @foreach (var mod in _imported)
                        {
                            var isActive = string.Equals(mod.Slug, ModContext.CurrentSlug,
                                StringComparison.OrdinalIgnoreCase);
                            <MudListItem T="Mod" Style="border-bottom:1px solid #1f1f4f;">
                                <div class="d-flex align-center gap-2">
                                    <MudIcon Icon="@(isActive
                                        ? Icons.Material.Filled.CheckCircle
                                        : Icons.Material.Outlined.RadioButtonUnchecked)"
                                             Color="@(isActive ? Color.Success : Color.Default)" />
                                    <div style="flex:1;">
                                        <MudText Typo="Typo.body1" Style="color:#fff; font-weight:600;">
                                            @mod.Name
                                        </MudText>
                                        <MudText Typo="Typo.caption" Style="color:#888;">
                                            @mod.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                        </MudText>
                                    </div>
                                    @if (!isActive)
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Text"
                                                   Color="Color.Warning"
                                                   OnClick="() => SetActive(mod)">
                                            Ativar
                                        </MudButton>
                                    }
                                    <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                                   Size="Size.Small" Color="Color.Default"
                                                   Title="Configurar imagens"
                                                   OnClick="() => OpenConfigAsync(mod)" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small" Color="Color.Error"
                                                   OnClick="() => DeleteAsync(mod)" />
                                </div>
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<CatalogEntry> _catalog = [];
    private List<Mod> _imported = [];
    private bool _loadingCatalog;
    private string? _importing;
    private int _importPercent;
    private string _importMessage = "";
    private DateTime? _catalogTimestamp;

    protected override async Task OnInitializedAsync()
    {
        ModContext.Changed += OnModChanged;
        await ReloadInstalledAsync();
        await LoadCatalogAsync(forceRefresh: false);
    }

    public void Dispose()
    {
        ModContext.Changed -= OnModChanged;
    }

    private async void OnModChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCatalogAsync(bool forceRefresh)
    {
        _loadingCatalog = true;
        StateHasChanged();
        try
        {
            _catalog = (await Catalog.GetAsync(forceRefresh)).ToList();
            _catalogTimestamp = Catalog.GetCacheTimestamp();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro carregando catálogo: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingCatalog = false;
            StateHasChanged();
        }
    }

    private Task RefreshCatalogAsync() => LoadCatalogAsync(forceRefresh: true);

    private async Task ReloadInstalledAsync()
    {
        _imported = (await ModRepo.ListAsync())
            .OrderByDescending(m => m.CreatedAt)
            .ToList();
    }

    private async Task ImportAsync(CatalogEntry entry)
    {
        if (_importing is not null) return;

        _importing = entry.Id;
        _importPercent = 0;
        _importMessage = "Iniciando…";
        StateHasChanged();

        var progress = new Progress<ModImporter.ImportProgress>(p =>
        {
            _importPercent = p.Percent;
            _importMessage = p.Message;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            var mod = await Importer.ImportAsync(entry, progress);
            await ReloadInstalledAsync();
            Snackbar.Add($"'{mod.Name}' importado.", Severity.Success);

            // Auto-ativa SEMPRE depois de importar — o usuário acabou de
            // expressar intenção de usar esse mod. Se já tinha outro ativo
            // (possivelmente quebrado / com estrutura velha), troca pra esse
            // e força reload pra nova estrutura ser detectada na hora.
            if (string.Equals(ModContext.CurrentSlug, mod.Slug,
                    StringComparison.OrdinalIgnoreCase))
            {
                // Re-importou o mesmo mod (mesmo slug) — ModContext.Set
                // teria sido no-op por ReferenceEquals. Força reload do cache.
                _ = ModCache.ReloadAsync();
            }
            else
            {
                SetActive(mod);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha ao importar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = null;
            StateHasChanged();
        }
    }

    private void SetActive(Mod mod)
    {
        ModContext.Set(mod);
        Snackbar.Add($"Mod ativo: {mod.Name}", Severity.Info);
    }

    private async Task OpenConfigAsync(Mod mod)
    {
        var p = new DialogParameters { ["Mod"] = mod };
        var opts = new DialogOptions
        {
            CloseButton  = true,
            MaxWidth     = MaxWidth.Medium,
            FullWidth    = true,
            BackdropClick = false,
        };
        var dlg = await DialogService.ShowAsync<ModConfigDialog>("Configurar MOD", p, opts);
        var result = await dlg.Result;
        if (result is not null && !result.Canceled)
            await ReloadInstalledAsync();
    }

    private async Task DeleteAsync(Mod mod)
    {
        var ok = await DialogService.ShowMessageBox(
            "Remover mod",
            $"Apagar '{mod.Name}' do disco? Esta ação não pode ser desfeita.",
            yesText: "Apagar", cancelText: "Cancelar");
        if (ok != true) return;

        try
        {
            await ModRepo.DeleteAsync(mod.Slug);
            if (string.Equals(ModContext.CurrentSlug, mod.Slug,
                    StringComparison.OrdinalIgnoreCase))
                ModContext.Set(null);
            await ReloadInstalledAsync();
            Snackbar.Add("Mod removido.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao remover: {ex.Message}", Severity.Error);
        }
    }

    private string CatalogStatusText
    {
        get
        {
            if (_catalogTimestamp is null) return "Catálogo nunca baixado.";
            var age = DateTime.UtcNow - _catalogTimestamp.Value;
            var expiresIn = TimeSpan.FromDays(30) - age;
            if (expiresIn <= TimeSpan.Zero)
                return $"Cache expirado ({_catalogTimestamp:yyyy-MM-dd}). Atualize.";
            return $"Cache de {_catalogTimestamp:yyyy-MM-dd HH:mm} · " +
                   $"expira em {(int)expiresIn.TotalDays} dia(s).";
        }
    }

    private static string ImportSlug(CatalogEntry entry)
        => yugiho_tools.Infrastructure.Storage.FileModRepository.Slugify(entry.Name);
}
