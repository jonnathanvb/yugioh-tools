    /// <summary>Traduz UM MOD específico (clique no botão da linha).
    /// Trava global via <see cref="_translatingSlug"/> — enquanto não
    /// for null, os outros botões ficam desabilitados. Recarrega o
    /// RomCache quando termina pra a UI refletir as traduções.</summary>
    private async Task TranslateMod(Mod mod)
    {
        if (!Cfg.TranslationConfigured)
        {
            Snackbar.Add(L.T("settings.claude.notConfigured"), Severity.Warning);
            return;
        }
        if (_translatingSlug != null) return;  // outro mod já em curso

        _translatingSlug     = mod.Slug;
        _translatingProgress = "";
        _translateCts        = new CancellationTokenSource();
        var ct = _translateCts.Token;

        var errors = new List<string>();
        var stepProgress = new Progress<ModExtractor.ExtractionStep>(s =>
        {
            if (s.Message.Contains("falhou", StringComparison.OrdinalIgnoreCase))
                errors.Add(s.Message);
            else
            {
                _translatingProgress = s.Message;
                InvokeAsync(StateHasChanged);
            }
        });

        try
        {
            await Extractor.TranslateModAsync(mod, stepProgress, ct);
            // Se o MOD traduzido for o ativo, recarrega o cache pra
            // que CardDetailDialog reflita as traduções imediatamente.
            if (ModContext.CurrentSlug == mod.Slug)
                await RomCache.ReloadAsync();

            foreach (var e in errors.Take(3)) Snackbar.Add(e, Severity.Warning);
            Snackbar.Add(L.T("settings.claude.translateDone"), Severity.Success);
        }
        catch (OperationCanceledException)
        {
            Snackbar.Add(L.T("common.cancel"), Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{mod.Name}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _translateCts?.Dispose();
            _translateCts        = null;
            _translatingSlug     = null;
            _translatingProgress = "";
        }
    }

    private void CancelTranslation() => _translateCts?.Cancel();

    private void OnModContextChanged() => InvokeAsync(StateHasChanged);
    private void OnLocaleChanged()     => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        ModContext.Changed -= OnModContextChanged;
        L.Changed          -= OnLocaleChanged;
    }

    private void SetActive(Mod mod)
    {
        ModContext.Set(mod);
        Snackbar.Add(L.T("mods.activated", mod.Name), Severity.Success);
    }

    /// <summary>
    /// Abre o popup de extração e espera o usuário fechar. Roda em
    /// thread de UI; o ModExtractor internamente usa Task.Run pro
    /// trabalho pesado, então a UI continua responsiva.
    /// </summary>
    private async Task OpenExtractionDialog(Mod mod, string? jsonPath = null,
                                            bool hasExtraDuelist = false,
                                            ModExtractor.DescriptionSource descSource = ModExtractor.DescriptionSource.Rom)
    {
        var parameters = new DialogParameters
        {
            ["Mod"] = mod,
            ["JsonPath"] = jsonPath,
            ["HasExtraDuelist"] = hasExtraDuelist,
            ["DescriptionSource"] = descSource,
        };
        var options = new DialogOptions
        {
            CloseButton  = false,
            BackdropClick = false,
            CloseOnEscapeKey = false,
            MaxWidth = MaxWidth.Small, FullWidth = true,
        };
        var dlg = await DialogService.ShowAsync<ModExtractionDialog>(
            "Extraindo MOD", parameters, options);
        await dlg.Result;
        // Re-renderiza pra atualizar o ícone (Warning → Success).
        StateHasChanged();
    }

    private void OnCatalogChanged(ModCatalogEntry? entry) => _selectedCatalog = entry;

    private Task<IEnumerable<ModCatalogEntry>> SearchCatalog(string? value, CancellationToken token)
    {
        IEnumerable<ModCatalogEntry> result = _catalog;
        if (!string.IsNullOrWhiteSpace(value))
        {
            var term = value.Trim();
            result = _catalog.Where(e =>
                e.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                e.Path.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                e.Id.Contains(term, StringComparison.OrdinalIgnoreCase));
        }
        return Task.FromResult(result.Take(50));
    }

