@page "/mods"
@using yugiho_tools.Application.Services
@using yugiho_tools.Application.UseCases
@using yugiho_tools.Domain.Entities
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@inject RegisterModUseCase RegisterModUseCase
@inject ListModsUseCase ListModsUseCase
@inject DeleteModUseCase DeleteModUseCase
@inject yugiho_tools.Application.Services.ModCatalogService ModCatalog
@inject yugiho_tools.Application.Services.CurrentModContext ModContext
@inject yugiho_tools.Application.Services.LocalizationService L
@inject yugiho_tools.Application.Services.AppSettings Cfg
@inject yugiho_tools.Application.Services.ModExtractor Extractor
@inject yugiho_tools.Application.Services.LoadedRomCache RomCache
@inject yugiho_tools.Domain.Interfaces.IModRepository ModRepo
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.False" Class="py-6 px-4"
              Style="max-width:80%; margin-left:auto; margin-right:auto;">

    <div class="d-flex align-center mb-4 gap-2">
        <MudIcon Icon="@Icons.Material.Filled.LibraryBooks"
                 Style="color:#c8a415; font-size:2rem;" />
        <div>
            <MudText Typo="Typo.overline"
                     Style="color:#888; letter-spacing:2px;">@L.T("mods.subtitle")</MudText>
            <MudText Typo="Typo.h5" Style="color:#c8a415; font-weight:700;">
                @L.T("mods.title")
            </MudText>
        </div>
    </div>

    <MudGrid Spacing="3">
        <!-- ─── Cadastro ────────────────────────────────────────── -->
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;"
                         Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.AddCircle"
                             Class="mr-1" Size="Size.Small" />
                    @L.T("mods.registerNew")
                </MudText>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />

                <MudAutocomplete T="ModCatalogEntry"
                                 Value="_selectedCatalog"
                                 ValueChanged="OnCatalogChanged"
                                 SearchFunc="SearchCatalog"
                                 ToStringFunc="@(e => e?.Name ?? "")"
                                 Label="MOD"
                                 Variant="Variant.Outlined"
                                 Class="mb-3"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="false"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.LibraryBooks"
                                 HelperText="@HelperCatalogText" />


                <div class="@FileZoneClass(_newGamePath)" @onclick="PickGameFile">
                    <MudPaper Class="pa-3" Elevation="0" Style="background:transparent;">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Memory"
                                     Style="@FileIconStyle(_newGamePath)" />
                            <div style="flex:1;">
                                <MudText Typo="Typo.body2" Style="color:#c8a415; font-weight:700;">
                                    SLUS_014.11
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color:#888;">
                                    @(_newGamePath != null
                                        ? Path.GetFileName(_newGamePath)
                                        : L.T("mods.pickSlus"))
                                </MudText>
                            </div>
                            @if (_newGamePath != null)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                         Color="Color.Success" />
                            }
                        </div>
                    </MudPaper>
                </div>

                <div class="@FileZoneClass(_newMrgPath)" @onclick="PickMrgFile" style="margin-top:8px;">
                    <MudPaper Class="pa-3" Elevation="0" Style="background:transparent;">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Storage"
                                     Style="@FileIconStyle(_newMrgPath)" />
                            <div style="flex:1;">
                                <MudText Typo="Typo.body2" Style="color:#c8a415; font-weight:700;">
                                    WA_MRG.MRG
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color:#888;">
                                    @(_newMrgPath != null
                                        ? Path.GetFileName(_newMrgPath)
                                        : L.T("mods.pickMrg"))
                                </MudText>
                            </div>
                            @if (_newMrgPath != null)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                         Color="Color.Success" />
                            }
                        </div>
                    </MudPaper>
                </div>

                @* Input opcional: JSON pré-extraído (ex: ygopro-lab data.pro
                   descompactado). Se fornecido, sobrescreve nossa leitura
                   binária dos dados (cartas, duelistas, drops). Imagens
                   continuam vindo do MRG. *@
                <div class="@FileZoneClass(_newJsonPath)" @onclick="PickJsonFile" style="margin-top:8px;">
                    <MudPaper Class="pa-3" Elevation="0" Style="background:transparent;">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.DataObject"
                                     Style="@FileIconStyle(_newJsonPath)" />
                            <div style="flex:1;">
                                <MudText Typo="Typo.body2" Style="color:#c8a415; font-weight:700;">
                                    @L.T("mods.jsonOptional")
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color:#888;">
                                    @(_newJsonPath != null
                                        ? Path.GetFileName(_newJsonPath)
                                        : L.T("mods.pickJson"))
                                </MudText>
                            </div>
                            @if (_newJsonPath != null)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                         Color="Color.Success" />
                            }
                        </div>
                    </MudPaper>
                </div>

                @* Fonte da Description: ROM (binário) ou JSON do lab.
                   Cada mod fica diferente — alguns o JSON tem texto rico
                   com marcadores, outros tem placeholders crus que nosso
                   decoder não interpreta. Usuário escolhe na hora do
                   cadastro qual fonte é melhor pro mod dele. *@
                <div class="mt-3" style="padding:8px 10px; background:#15152e; border-radius:6px;
                                         border:1px solid #2a2a6e;">
                    <MudText Typo="Typo.caption" Style="color:#888; letter-spacing:1px;" Class="mb-1">
                        @L.T("mods.descSource")
                    </MudText>
                    <MudToggleGroup T="ModExtractor.DescriptionSource"
                                    SelectionMode="SelectionMode.SingleSelection"
                                    Value="@_descriptionSource"
                                    ValueChanged="@(v => _descriptionSource = v)"
                                    Color="Color.Secondary"
                                    Dense="true"
                                    CheckMark="false">
                        <MudToggleItem Value="ModExtractor.DescriptionSource.Rom">
                            <div class="d-flex align-center gap-1">
                                <MudIcon Icon="@Icons.Material.Filled.Memory" Size="Size.Small" />
                                @L.T("mods.descSource.rom")
                            </div>
                        </MudToggleItem>
                        <MudToggleItem Value="ModExtractor.DescriptionSource.Json">
                            <div class="d-flex align-center gap-1">
                                <MudIcon Icon="@Icons.Material.Filled.DataObject" Size="Size.Small" />
                                @L.T("mods.descSource.json")
                            </div>
                        </MudToggleItem>
                    </MudToggleGroup>
                    <MudText Typo="Typo.caption" Style="color:#888; display:block;" Class="mt-1">
                        @L.T("mods.descSourceHelp")
                    </MudText>
                </div>

                @* Flag pra mods com duelista extra (ex.: Rakuza no TLM).
                   Quando marcada, o extrator usa offset deslocado e lê 40
                   portraits — Rakuza vira o índice 0 e os demais empurram
                   pra +1, batendo com o comportamento *@
                <div class="mt-3" style="padding:8px 10px; background:#15152e; border-radius:6px;
                                         border:1px solid #2a2a6e;">
                    <MudCheckBox T="bool"
                                 Value="_hasExtraDuelist"
                                 ValueChanged="@(v => _hasExtraDuelist = v)"
                                 Color="Color.Primary"
                                 Dense="true">
                        <MudText Typo="Typo.body2" Style="color:#cfcfe0;">
                            @L.T("mods.extraDuelist")
                        </MudText>
                    </MudCheckBox>
                    <MudText Typo="Typo.caption" Style="color:#888; padding-left:32px; display:block;">
                        @L.T("mods.extraDuelistHelp")
                    </MudText>
                </div>

                <div class="d-flex align-center mt-1" style="padding-left:4px;">
                    <MudIcon Icon="@Icons.Material.Filled.Download"
                             Size="Size.Small" Style="color:#888; font-size:0.9rem;" Class="mr-1" />
                    <MudLink Href="template-mod-data.json"
                             Target="_blank"
                             Download="template-mod-data.json"
                             Typo="Typo.caption"
                             Style="color:#c8a415;">
                        @L.T("mods.downloadTemplate")
                    </MudLink>
                </div>

                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           FullWidth="true" Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="SaveMod"
                           Disabled="@(!CanSave || _isSaving)"
                           Class="mt-4"
                           Style="font-weight:700; letter-spacing:1px;">
                    @(_isSaving ? L.T("mods.saving") : L.T("mods.registerButton"))
                </MudButton>
            </MudPaper>
        </MudItem>

        @* ── Tradução (provider + endpoints) ──────────────────────
           Movido pra cá pra que a config fique perto do botão
           "Translate" de cada MOD. Settings só cuida das prefs gerais
           do app agora. *@
        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4 mb-3" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;"
                         Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Translate"
                             Class="mr-1" Size="Size.Small" />
                    @L.T("settings.claude.title")
                </MudText>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />

                <MudText Typo="Typo.caption" Style="color:#888;" Class="mb-3 d-block">
                    @L.T("settings.claude.desc")
                </MudText>

                @* Toggle de provider único — só uma integração ativa
                   por vez. Os campos abaixo se adaptam ao escolhido. *@
                <MudToggleGroup T="string"
                                SelectionMode="SelectionMode.SingleSelection"
                                Value="@_translationProvider"
                                ValueChanged="@OnProviderChanged"
                                Color="Color.Secondary"
                                CheckMark="false"
                                Class="mb-3">
                    <MudToggleItem Value="@("claude")">
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.Cloud" Size="Size.Small" />
                            @L.T("settings.translation.providerClaude")
                        </div>
                    </MudToggleItem>
                    <MudToggleItem Value="@("deepl")">
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.Translate" Size="Size.Small" />
                            DeepL
                        </div>
                    </MudToggleItem>
                    <MudToggleItem Value="@("ollama")">
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.Computer" Size="Size.Small" />
                            @L.T("settings.translation.providerOllama")
                        </div>
                    </MudToggleItem>
                    <MudToggleItem Value="@("lmstudio")">
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.Memory" Size="Size.Small" />
                            LM Studio
                        </div>
                    </MudToggleItem>
                </MudToggleGroup>

                @if (_translationProvider == "claude")
                {
                    <MudGrid Spacing="2" Class="mb-3">
                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Value="@_claudeApiKey"
                                          ValueChanged="@OnClaudeApiKeyChanged"
                                          Label="@L.T("settings.claude.apiKey")"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          InputType="InputType.Password"
                                          HelperText="@L.T("settings.claude.apiKeyHelp")" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField T="string"
                                          Value="@_claudeModel"
                                          ValueChanged="@OnClaudeModelChanged"
                                          Label="@L.T("settings.claude.model")"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField T="string"
                                          Value="@_claudeBaseUrl"
                                          ValueChanged="@OnClaudeBaseUrlChanged"
                                          Label="@L.T("settings.claude.baseUrl")"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>
                }
                else if (_translationProvider == "deepl")
                {
                    <MudGrid Spacing="2" Class="mb-3">
                        <MudItem xs="12" md="8">
                            <MudTextField T="string"
                                          Value="@_deepLApiKey"
                                          ValueChanged="@OnDeepLApiKeyChanged"
                                          Label="@L.T("settings.deepl.apiKey")"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          InputType="InputType.Password"
                                          HelperText="@L.T("settings.deepl.apiKeyHelp")" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudSelect T="string"
                                       Value="@_deepLPlan"
                                       ValueChanged="@OnDeepLPlanChanged"
                                       Label="@L.T("settings.deepl.plan")"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense">
                                <MudSelectItem Value="@("free")">Free (api-free.deepl.com)</MudSelectItem>
                                <MudSelectItem Value="@("pro")">Pro (api.deepl.com)</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                }
                else if (_translationProvider == "ollama")
                {
                    <MudGrid Spacing="2" Class="mb-3">
                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Value="@_ollamaBaseUrl"
                                          ValueChanged="@OnOllamaBaseUrlChanged"
                                          Label="@L.T("settings.ollama.baseUrl")"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          HelperText="@L.T("settings.ollama.baseUrlHelp")" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField T="string"
                                          Value="@_ollamaModel"
                                          ValueChanged="@OnOllamaModelChanged"
                                          Label="@L.T("settings.ollama.model")"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          HelperText="@L.T("settings.ollama.modelHelp")" />
                        </MudItem>
                    </MudGrid>
                }
                else if (_translationProvider == "lmstudio")
                {
                    <MudGrid Spacing="2" Class="mb-3">
                        <MudItem xs="12" md="5">
                            <MudTextField T="string"
                                          Value="@_lmStudioBaseUrl"
                                          ValueChanged="@OnLmStudioBaseUrlChanged"
                                          Label="@L.T("settings.lmstudio.baseUrl")"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          HelperText="@L.T("settings.lmstudio.baseUrlHelp")" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudTextField T="string"
                                          Value="@_lmStudioModel"
                                          ValueChanged="@OnLmStudioModelChanged"
                                          Label="@L.T("settings.lmstudio.model")"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          HelperText="@L.T("settings.lmstudio.modelHelp")" />
                        </MudItem>
                        <MudItem xs="12" md="3">
                            <MudTextField T="string"
                                          Value="@_lmStudioApiKey"
                                          ValueChanged="@OnLmStudioApiKeyChanged"
                                          Label="@L.T("settings.lmstudio.apiKey")"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          InputType="InputType.Password"
                                          HelperText="@L.T("settings.lmstudio.apiKeyHelp")" />
                        </MudItem>
                    </MudGrid>
                }

                <MudCheckBox T="bool"
                             Value="@_autoTranslate"
                             ValueChanged="@OnAutoTranslateChanged"
                             Color="Color.Primary"
                             Label="@L.T("settings.claude.autoTranslate")"
                             Class="mt-2" />
            </MudPaper>
        </MudItem>

        <!-- ─── Lista ───────────────────────────────────────────── -->
        <MudItem xs="12" >
            <MudPaper Class="pa-4" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;"
                         Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory"
                             Class="mr-1" Size="Size.Small" />
                    @L.T("mods.registered", _mods.Count)
                </MudText>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />

                @if (_mods.Count == 0)
                {
                    <MudAlert Severity="Severity.Info"
                              Style="background:#0d1520; border:1px solid #2a5a8e;">
                        @L.T("mods.empty")
                    </MudAlert>
                }
                else
                {
                    <MudList T="Mod" Dense="true">
                        @foreach (var mod in _mods)
                        {
                            var modRef = mod;
                            var isActive = ModContext.CurrentSlug == modRef.Slug;
                            <MudListItem T="Mod"
                                         Style="@($"background:{(isActive ? "#15301a" : "#0a0a18")};" +
                                                 $" border:1px solid {(isActive ? "#4caf50" : "#1e1e4a")};" +
                                                 " border-radius:6px; margin-bottom:8px;")">
                                <div class="d-flex align-center justify-space-between gap-2">
                                    <div style="flex:1;">
                                        <div class="d-flex align-center gap-2">
                                            <MudText Style="font-weight:700; color:#c8a415;">
                                                @modRef.Name
                                            </MudText>
                                            @if (isActive)
                                            {
                                                <MudChip T="string" Size="Size.Small"
                                                         Color="Color.Success" Variant="Variant.Filled"
                                                         Icon="@Icons.Material.Filled.CheckCircle">
                                                    @L.T("mods.active")
                                                </MudChip>
                                            }
                                        </div>
                                        <MudText Typo="Typo.caption" Style="color:#888;">
                                            <code>MOD/@modRef.Slug</code> ·
                                            @modRef.GameFileName · @modRef.MrgFileName ·
                                            @modRef.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                        </MudText>
                          
                                    </div>
                                    <div class="d-flex align-center gap-1">
                                        @* Extração agora é automática no cadastro — não tem
                                           mais botão "extrair" aqui. Pra re-processar, o
                                           usuário precisa apagar e cadastrar de novo. *@
                                        @{
                                            var translatingThis = _translatingSlug == modRef.Slug;
                                            var canTranslate    = Cfg.TranslationConfigured
                                                                  && _translatingSlug == null;
                                        }
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Outlined"
                                                   Color="@(translatingThis ? Color.Warning : Color.Primary)"
                                                   StartIcon="@(translatingThis
                                                       ? Icons.Material.Filled.HourglassEmpty
                                                       : Icons.Material.Filled.Translate)"
                                                   OnClick="@(() => TranslateMod(modRef))"
                                                   Disabled="@(!canTranslate && !translatingThis)">
                                            @(translatingThis
                                                ? L.T("mods.translateInProgress")
                                                : L.T("mods.translate"))
                                        </MudButton>
                                        @if (translatingThis)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                                           Color="Color.Error" Size="Size.Small"
                                                           OnClick="CancelTranslation"
                                                           title="@L.T("common.cancel")" />
                                        }
                                        @if (!isActive)
                                        {
                                            <MudButton Size="Size.Small"
                                                       Variant="Variant.Outlined" Color="Color.Success"
                                                       StartIcon="@Icons.Material.Filled.CheckCircle"
                                                       OnClick="@(() => SetActive(modRef))">
                                                @L.T("mods.setActive")
                                            </MudButton>
                                        }
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error" Size="Size.Small"
                                                       OnClick="@(() => DeleteMod(modRef))"
                                                       Disabled="@(_translatingSlug != null)" />
                                    </div>
                                </div>
                                @if (translatingThis && !string.IsNullOrEmpty(_translatingProgress))
                                {
                                    <div class="mt-2">
                                        <MudProgressLinear Indeterminate="true" Color="Color.Primary"
                                                           Rounded="true" Size="Size.Small" />
                                        <MudText Typo="Typo.caption" Style="color:#888;" Class="mt-1 d-block">
                                            @_translatingProgress
                                        </MudText>
                                    </div>
                                }
                            </MudListItem>
                        }
                    </MudList>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

</MudContainer>

@code {
    private string? _newGamePath;
    private string? _newMrgPath;
    private string? _newJsonPath;
    private bool    _hasExtraDuelist;
    private ModExtractor.DescriptionSource _descriptionSource = ModExtractor.DescriptionSource.Rom;
    private ModCatalogEntry? _selectedCatalog;
    private bool    _isSaving;
    private List<Mod> _mods = [];
    private List<ModCatalogEntry> _catalog = [];

    // ── Tradução ─────────────────────────────────────────────────
    private string _translationProvider = AppSettings.DefaultTranslationProvider;
    private string _claudeApiKey    = "";
    private string _claudeModel     = AppSettings.DefaultClaudeModel;
    private string _claudeBaseUrl   = AppSettings.DefaultClaudeBaseUrl;
    private string _ollamaBaseUrl   = AppSettings.DefaultOllamaBaseUrl;
    private string _ollamaModel     = AppSettings.DefaultOllamaModel;
    private string _lmStudioBaseUrl = AppSettings.DefaultLmStudioBaseUrl;
    private string _lmStudioModel   = AppSettings.DefaultLmStudioModel;
    private string _lmStudioApiKey  = "";
    private string _deepLApiKey     = "";
    private string _deepLPlan       = AppSettings.DefaultDeepLPlan;
    private bool   _autoTranslate;

    /// <summary>Slug do MOD que está sendo traduzido AGORA. Null = nada
    /// rodando, então qualquer linha pode iniciar. Travamos um único
    /// MOD por vez pra não brigar pelos endpoints do Ollama nem
    /// estourar rate-limit do Claude.</summary>
    private string? _translatingSlug;
    private string  _translatingProgress = "";
    private CancellationTokenSource? _translateCts;

    private bool CanSave =>
        _selectedCatalog != null &&
        _newGamePath != null &&
        _newMrgPath != null;

    private string HelperCatalogText =>
        _selectedCatalog is null
            ? L.T("mods.searchHelp")
            : L.T("mods.selected");

    private string PreviewUrl =>
        _selectedCatalog is null
            ? ""
            : ModCatalogService.BuildImageUrlTemplate(_selectedCatalog);

    private string SlugPreview =>
        _selectedCatalog is null
            ? ""
            : Slugify(_selectedCatalog.Name);

    protected override async Task OnInitializedAsync()
    {
        _catalog = (await ModCatalog.GetAllAsync()).ToList();
        await Reload();
        // Carrega config de tradução do AppSettings.
        _translationProvider = Cfg.TranslationProvider;
        _claudeApiKey    = Cfg.ClaudeApiKey;
        _claudeModel     = Cfg.ClaudeModel;
        _claudeBaseUrl   = Cfg.ClaudeBaseUrl;
        _ollamaBaseUrl   = Cfg.OllamaBaseUrl;
        _ollamaModel     = Cfg.OllamaModel;
        _lmStudioBaseUrl = Cfg.LmStudioBaseUrl;
        _lmStudioModel   = Cfg.LmStudioModel;
        _lmStudioApiKey  = Cfg.LmStudioApiKey;
        _deepLApiKey     = Cfg.DeepLApiKey;
        _deepLPlan       = Cfg.DeepLPlan;
        _autoTranslate   = Cfg.AutoTranslateOnExtract;
        ModContext.Changed += OnModContextChanged;
        L.Changed          += OnLocaleChanged;
    }

    // ── Translation config handlers ─────────────────────────────────
    private void OnProviderChanged(string v)        { _translationProvider = v ?? AppSettings.DefaultTranslationProvider; Cfg.TranslationProvider = _translationProvider; }
    private void OnClaudeApiKeyChanged(string v)    { _claudeApiKey = v ?? ""; Cfg.ClaudeApiKey = _claudeApiKey; }
    private void OnClaudeModelChanged(string v)     { _claudeModel = v ?? AppSettings.DefaultClaudeModel; Cfg.ClaudeModel = _claudeModel; }
