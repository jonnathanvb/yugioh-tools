    private async Task SaveMod()
    {
        if (!CanSave) return;
        _isSaving = true;
        try
        {
            var template = ModCatalogService.BuildImageUrlTemplate(_selectedCatalog!);
            var mod = await RegisterModUseCase.ExecuteAsync(
                _selectedCatalog!.Name, _newGamePath!, _newMrgPath!, template);
            Snackbar.Add(L.T("mods.registered.success", mod.Name, mod.Slug), Severity.Success);

            var jsonPath = _newJsonPath;
            var hasExtra = _hasExtraDuelist;
            var descSource = _descriptionSource;
            _newGamePath = null;
            _newMrgPath = null;
            _newJsonPath = null;
            _hasExtraDuelist = false;
            _descriptionSource = ModExtractor.DescriptionSource.Rom;
            _selectedCatalog = null;
            await Reload();

            // Dispara extração automática logo após o cadastro — usuário
            // espera UMA vez e depois leituras são instantâneas via JSON.
            await OpenExtractionDialog(mod, jsonPath, hasExtra, descSource);

            // Se é o primeiro MOD, ativa automaticamente — usuário não
            // precisa clicar em "Definir como ativo" pra começar a usar.
            if (_mods.Count == 1) SetActive(mod);
        }
        catch (Exception ex)
        {
            Snackbar.Add(L.T("mods.registerError", ex.Message), Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteMod(Mod mod)
    {
        var confirm = await DialogService.ShowMessageBox(
            L.T("mods.deleteTitle"),
            L.T("mods.deleteConfirm", mod.Name),
            yesText: L.T("common.remove"), cancelText: L.T("common.cancel"));
        if (confirm != true) return;

        try
        {
            await DeleteModUseCase.ExecuteAsync(mod.Slug);
            // Se removeu o ativo, limpa o contexto.
            if (ModContext.CurrentSlug == mod.Slug) ModContext.Set(null);
            Snackbar.Add(L.T("mods.deleted", mod.Name), Severity.Info);
            await Reload();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
    }
