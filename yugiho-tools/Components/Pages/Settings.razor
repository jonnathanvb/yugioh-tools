@page "/settings"
@using yugiho_tools.Application.Services
@using Color = MudBlazor.Color
@using Size = MudBlazor.Size
@inject AppSettings Cfg
@inject LocalizationService L
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject UpdateService Updates
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.False" Class="py-6 px-4"
              Style="max-width:80%; margin-left:auto; margin-right:auto;">

    <div class="d-flex align-center mb-4 gap-2">
        <MudIcon Icon="@Icons.Material.Filled.Settings"
                 Style="color:#c8a415; font-size:2rem;" />
        <div>
            <MudText Typo="Typo.overline"
                     Style="color:#888; letter-spacing:2px;">@L.T("settings.subtitle")</MudText>
            <MudText Typo="Typo.h5" Style="color:#c8a415; font-weight:700;">
                @L.T("settings.title")
            </MudText>
        </div>
    </div>

    <MudGrid Spacing="3">

        <!-- ─── Linha 1: Idioma | Catálogo ───────────────────────── -->
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 h-100" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;"
                         Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Language"
                             Class="mr-1" Size="Size.Small" />
                    @L.T("settings.language")
                </MudText>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />

                <MudSelect T="string" Value="_language"
                           ValueChanged="OnLanguageChanged"
                           Variant="Variant.Outlined" Dense="true"
                           HelperText="@L.T("settings.languageHelp")">
                    @foreach (var lang in L.SupportedLanguages)
                    {
                        <MudSelectItem T="string" Value="@lang">
                            @LocalizationService.DisplayName(lang)
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 h-100" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;"
                         Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.GridView"
                             Class="mr-1" Size="Size.Small" />
                    @L.T("settings.catalogTitle")
                </MudText>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />

                <MudNumericField T="int"
                                 Value="@_maxGridCards"
                                 ValueChanged="@OnMaxGridCardsChanged"
                                 Label="@L.T("settings.maxCards")"
                                 Variant="Variant.Outlined"
                                 Min="1" Max="722" Step="10"
                                 HelperText="@L.T("settings.maxCardsHelp", AppSettings.DefaultMaxGridCards)" />
            </MudPaper>
        </MudItem>

        <!-- ─── Linha 2: Imagens das cartas (largura cheia) ──────── -->
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;"
                         Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Image"
                             Class="mr-1" Size="Size.Small" />
                    @L.T("settings.imageSourceTitle")
                </MudText>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />

                <MudText Typo="Typo.caption" Style="color:#888;" Class="mb-2 d-block">
                    @L.T("settings.imageSourceFullDesc")
                </MudText>

                <MudToggleGroup T="ImageSource"
                                SelectionMode="SelectionMode.SingleSelection"
                                Value="_imageSource"
                                ValueChanged="OnImageSourceChanged"
                                Color="Color.Secondary"
                                CheckMark="false">
                    <MudToggleItem Value="ImageSource.Tea">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Cloud" Size="Size.Small" />
                            <div>
                                <div style="font-weight:600;">@L.T("settings.imageSourceTea")</div>
                                <MudText Typo="Typo.caption" Style="color:#888;">
                                    @L.T("settings.imageSourceTeaDesc")
                                </MudText>
                            </div>
                        </div>
                    </MudToggleItem>
                    <MudToggleItem Value="ImageSource.Mod">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Save" Size="Size.Small" />
                            <div>
                                <div style="font-weight:600;">@L.T("settings.imageSourceMod")</div>
                                <MudText Typo="Typo.caption" Style="color:#888;">
                                    @L.T("settings.imageSourceModDesc")
                                </MudText>
                            </div>
                        </div>
                    </MudToggleItem>
                </MudToggleGroup>

                @if (_imageSource == ImageSource.Mod)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3"
                              Style="background:#1a2a3a; border:1px solid #2a4a6e;">
                        @L.T("settings.modeMod.alert")
                    </MudAlert>
                }
            </MudPaper>
        </MudItem>

        <!-- ─── Linha 3: Atalho | Cores das cartas ───────────────── -->
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 h-100" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;"
                         Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Keyboard"
                             Class="mr-1" Size="Size.Small" />
                    @L.T("settings.shortcutTitle")
                </MudText>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />

                <div class="d-flex gap-2 mb-3 align-center">
                    <MudTextField T="string"
                                  Value="@_shortcutKey"
                                  Label="@L.T("settings.shortcutLabel")"
                                  Variant="Variant.Outlined"
                                  ReadOnly="true"
                                  Style="flex:1;"
                                  HelperText="@(_recording ? L.T("settings.shortcutHelpRecording") : L.T("settings.shortcutHelp"))" />
                    <input id="shortcut-capture-input"
                           tabindex="0"
                           style="position:absolute; left:-9999px; width:1px; height:1px;
                                  opacity:0; pointer-events:none;" />
                    <MudButton Variant="Variant.Outlined"
                               Color="@(_recording ? Color.Warning : Color.Primary)"
                               StartIcon="@Icons.Material.Filled.RadioButtonChecked"
                               OnClick="StartRecording"
                               Disabled="@_recording"
                               Style="height:56px;">
                        @(_recording ? L.T("settings.shortcutWaiting") : L.T("settings.shortcutRegister"))
                    </MudButton>
                </div>

                <MudText Typo="Typo.caption" Style="color:#888;" Class="mb-2">
                    @L.T("settings.shortcutActions")
                </MudText>

                <MudCheckBox T="bool"
                             Value="@_shortcutClearDeck"
                             ValueChanged="@OnClearDeckChanged"
                             Color="Color.Primary"
                             Label="@L.T("settings.shortcutClearDeck")" />
                <br />
                <MudCheckBox T="bool"
                             Value="@_shortcutScanEmulator"
                             ValueChanged="@OnScanEmulatorChanged"
                             Color="Color.Primary"
                             Label="@L.T("settings.shortcutScan")" />
                <br />
                <MudCheckBox T="bool"
                             Value="@_shortcutCalculateFusions"
                             ValueChanged="@OnCalculateFusionsChanged"
                             Color="Color.Primary"
                             Label="@L.T("settings.shortcutCalc")" />
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4 h-100" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <div class="d-flex align-center justify-space-between mb-2">
                    <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;">
                        <MudIcon Icon="@Icons.Material.Filled.Palette"
                                 Class="mr-1" Size="Size.Small" />
                        @L.T("settings.colorsTitle")
                    </MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Text"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="ResetDescriptionColors">
                        @L.T("settings.colorsRestore")
                    </MudButton>
                </div>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />

                <MudText Typo="Typo.caption" Style="color:#888;" Class="mb-3 d-block">
                    @L.T("settings.colorsDesc")
                </MudText>

                <div class="d-flex flex-column gap-2">
                    @for (int i = 1; i < _descriptionColors.Length; i++)
                    {
                        var idx = i;
                        <div class="d-flex align-center gap-2">
                            <span style="@($"display:inline-block; width:20px; height:20px; " +
                                          $"border-radius:3px; border:1px solid #2a2a6e; " +
                                          $"background:{_descriptionColors[idx]};")"></span>
                            <MudText Typo="Typo.caption" Style="color:#888; min-width:42px;">
                                #@idx
                            </MudText>
                            <MudTextField T="string"
                                          Value="@_descriptionColors[idx]"
                                          ValueChanged="@(v => OnDescriptionColorChanged(idx, v))"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Style="flex:1; max-width:160px;" />
                        </div>
                    }
                </div>

                <MudText Typo="Typo.caption" Style="color:#666; font-style:italic;"
                         Class="mt-3 d-block">
                    Formato hexadecimal: <code>#RRGGBB</code>.
                </MudText>
            </MudPaper>
        </MudItem>

        <!-- ─── Auto-update ───────────────────────────────────────── -->
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="3"
                      Style="background:#141428; border:1px solid #2a2a6e;">
                <MudText Typo="Typo.subtitle1" Style="color:#c8a415; font-weight:700;"
                         Class="mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.SystemUpdate"
                             Class="mr-1" Size="Size.Small" />
                    Atualizações
                </MudText>
                <MudDivider Class="mb-3" Style="border-color:#2a2a6e;" />
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.CloudDownload"
                               OnClick="CheckUpdates" Disabled="_checkingUpdates">
                        @(_checkingUpdates ? "Verificando..." : "Verificar atualizações")
                    </MudButton>
                    <MudText Typo="Typo.caption" Style="color:#888;">
                        Releases publicadas no GitHub. A versão atual é atualizada automaticamente quando há novidades.
                    </MudText>
                </MudStack>
            </MudPaper>
        </MudItem>

    </MudGrid>

</MudContainer>

@code {
    private bool        _checkingUpdates;
    private int         _maxGridCards;
    private string      _shortcutKey = "";
    private bool        _shortcutClearDeck;
    private bool        _shortcutScanEmulator;
    private bool        _shortcutCalculateFusions;
    private bool        _recording;
    private ImageSource _imageSource;
    private string      _language = "pt";
    private string[]    _descriptionColors = AppSettings.DefaultDescriptionColors;

    private DotNetObjectReference<Settings>? _selfRef;

    protected override void OnInitialized()
    {
        _maxGridCards             = Cfg.MaxGridCards;
        _shortcutKey              = Cfg.ShortcutKey;
        _shortcutClearDeck        = Cfg.ShortcutClearDeck;
        _shortcutScanEmulator     = Cfg.ShortcutScanEmulator;
        _shortcutCalculateFusions = Cfg.ShortcutCalculateFusions;
        _imageSource              = Cfg.ImageSource;
        _language                 = L.Language;
        _descriptionColors        = Cfg.DescriptionColors;
        L.Changed += OnLocaleChanged;
    }

    private void OnDescriptionColorChanged(int idx, string value)
    {
        if (idx < 0 || idx >= _descriptionColors.Length) return;
        // Aceita o input parcial enquanto digita pra não perder foco; valida
        // só quando vira um hex completo. Se ainda não estiver válido, mantém
        // o valor visualmente mas não persiste.
        _descriptionColors[idx] = value ?? "";
        if (IsValidHex(value))
        {
            Cfg.DescriptionColors = _descriptionColors;
        }
    }

    private void ResetDescriptionColors()
    {
        _descriptionColors = (string[])AppSettings.DefaultDescriptionColors.Clone();
        Cfg.DescriptionColors = _descriptionColors;
        Snackbar.Add(L.T("settings.colorsRestored"), Severity.Success);
    }

    private static bool IsValidHex(string? s) =>
        !string.IsNullOrEmpty(s) && s.Length == 7 && s[0] == '#'
        && s.AsSpan(1).IndexOfAnyExcept(
            "0123456789abcdefABCDEF".AsSpan()) == -1;

    private void OnLocaleChanged() => InvokeAsync(StateHasChanged);

    private void OnLanguageChanged(string lang)
    {
        _language  = lang;
        L.Language = lang;
    }

    private void OnImageSourceChanged(ImageSource v)
    {
        _imageSource    = v;
        Cfg.ImageSource = v;
        Snackbar.Add(
            L.T(v == ImageSource.Mod ? "imageSource.changedToMod" : "imageSource.changedToTea"),
            Severity.Success);
    }

    private void OnMaxGridCardsChanged(int v)
    {
        _maxGridCards = Math.Max(1, v);
        Cfg.MaxGridCards = _maxGridCards;
    }

    private void OnClearDeckChanged(bool v)        { _shortcutClearDeck = v;        Cfg.ShortcutClearDeck = v; }
    private void OnScanEmulatorChanged(bool v)     { _shortcutScanEmulator = v;     Cfg.ShortcutScanEmulator = v; }
    private void OnCalculateFusionsChanged(bool v) { _shortcutCalculateFusions = v; Cfg.ShortcutCalculateFusions = v; }

    private async Task StartRecording()
    {
        _recording = true;
        _selfRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("yugihoKeyboard.captureNext",
            "shortcut-capture-input", _selfRef);
    }

    [JSInvokable]
    public void OnCaptureKey(string combo)
    {
        _shortcutKey      = combo;
        Cfg.ShortcutKey   = combo;
        _recording        = false;
        Snackbar.Add(L.T("settings.shortcutRegistered", combo), Severity.Success);
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        L.Changed -= OnLocaleChanged;
        _selfRef?.Dispose();
    }

    private async Task CheckUpdates()
    {
        _checkingUpdates = true;
        try
        {
            var result = await Updates.CheckAndApplyAsync();
            Snackbar.Add(result.Message, result.Updated ? Severity.Success : Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Falha ao verificar atualizações: {ex.Message}", Severity.Error);
        }
        finally
        {
            _checkingUpdates = false;
        }
    }
}
