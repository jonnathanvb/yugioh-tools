@using yugiho_tools.Application.Services
@using yugiho_tools.Domain.Entities
@inject ModExtractor Extractor

@*
   Popup de extração de dados do MOD. Roda automaticamente quando
   o diálogo abre — usuário só precisa esperar e ver o progresso.
   Cancela com tecla Escape.
*@
<MudDialog Style="background:#0d0d1a;">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Inventory2"
                     Style="color:#c8a415;" />
            <MudText Typo="Typo.h6" Style="color:#c8a415; font-weight:700;">
                Extraindo dados do MOD
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Style="color:#cfcfe0;" Class="mb-3">
            <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Size="Size.Small"
                     Style="color:#c8a415;" Class="mr-1" />
            <strong>@Mod.Name</strong>
            <span style="color:#666;"> · MOD/@Mod.Slug</span>
        </MudText>

        <MudProgressLinear Value="@_progress" Color="Color.Primary"
                           Rounded="true" Size="Size.Large" />

        <div class="d-flex align-center justify-space-between mt-2">
            <MudText Typo="Typo.caption" Style="color:#c8a415; font-weight:600;">
                @_message
            </MudText>
            <MudText Typo="Typo.caption" Style="color:#888;">
                @_progress%
            </MudText>
        </div>

        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3"
                      Style="background:#2a1010;">
                @_error
            </MudAlert>
        }
        else
        {
            <MudText Typo="Typo.caption" Style="color:#666;" Class="mt-3 d-block">
                Estamos extraindo cartas, fusões, equips e drops do ROM e
                salvando em <code>MOD/@Mod.Slug/data.json</code>. Aberturas
                futuras lerão direto desse arquivo — bem mais rápido que
                reparsear o ROM toda vez.
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        @if (_done)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="Close">
                Concluir
            </MudButton>
        }
        else if (_error is not null)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       OnClick="Close">
                Fechar
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       OnClick="Cancel">
                Cancelar
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter, EditorRequired] public Mod Mod { get; set; } = default!;
    [Parameter] public string? JsonPath { get; set; }
    [Parameter] public bool HasExtraDuelist { get; set; }
    [Parameter] public FieldSourceMatrix SourceMatrix { get; set; }
        = FieldSourceMatrix.DefaultAllJson;

    private int     _progress;
    private string  _message = "Iniciando…";
    private string? _error;
    private bool    _done;
    private CancellationTokenSource? _cts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Dispara a extração só uma vez, depois do primeiro render — pra
        // dialog aparecer já com o estado inicial visível.
        if (!firstRender || _cts is not null) return;
        _cts = new CancellationTokenSource();
        try
        {
            var progress = new Progress<ModExtractor.ExtractionStep>(s =>
            {
                _progress = s.Percent;
                _message  = s.Message;
                InvokeAsync(StateHasChanged);
            });
            await Extractor.ExtractAsync(Mod, progress, _cts.Token,
                externalJsonPath: JsonPath,
                hasExtraDuelist: HasExtraDuelist,
                sourceMatrix: SourceMatrix);
            _done = true;
        }
        catch (OperationCanceledException)
        {
            _error = "Extração cancelada pelo usuário.";
        }
        catch (Exception ex)
        {
            _error = $"Falha ao extrair: {ex.Message}";
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void Cancel()
    {
        _cts?.Cancel();
    }

    private void Close()
    {
        _cts?.Cancel();
        MudDialog.Close(DialogResult.Ok(_done));
    }
}
