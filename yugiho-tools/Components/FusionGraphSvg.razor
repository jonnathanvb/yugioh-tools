@using yugiho_tools.Application.DTOs
@using yugiho_tools.Application.Helpers
@using yugiho_tools.Domain.Entities

@if (_layout != null)
{
    <div style="width:100%; max-height:75vh; overflow:auto;
                background:#0a0a18; border-radius:6px; padding:8px;">
        <svg xmlns="http://www.w3.org/2000/svg"
             width="@F(_layout.Width)"
             height="@F(_layout.Height)"
             viewBox="0 0 @F(_layout.Width) @F(_layout.Height)"
             style="display:block;">

            <defs>
                @for (int ji = 0; ji < _layout.Junctions.Count; ji++)
                {
                    var color = PairColor(ji, _layout.Junctions.Count);
                    <marker id="@($"arrow_{_id}_{ji}")" viewBox="0 0 10 10" refX="9" refY="5"
                            markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                        <path d="M0,0 L10,5 L0,10 Z" fill="@color" />
                    </marker>
                }
            </defs>

            @* Material → Junction edges (unique color per fusion pair) *@
            @for (int ji = 0; ji < _layout.Junctions.Count; ji++)
            {
                var j = _layout.Junctions[ji];
                var color = PairColor(ji, _layout.Junctions.Count);
                @DrawCurve(j.Mat1.X + GraphLayout.NodeW / 2, j.Mat1.Y + GraphLayout.NodeH,
                           j.X, j.Y, color, "2", false)
                @DrawCurve(j.Mat2.X + GraphLayout.NodeW / 2, j.Mat2.Y + GraphLayout.NodeH,
                           j.X, j.Y, color, "2", false)
            }

            @* Junction → Result edges (with arrow, same pair color) *@
            @for (int ji = 0; ji < _layout.Junctions.Count; ji++)
            {
                var j = _layout.Junctions[ji];
                var color = PairColor(ji, _layout.Junctions.Count);
                @DrawCurve(j.X, j.Y,
                           j.Result.X + GraphLayout.NodeW / 2, j.Result.Y,
                           color, "2.5", true, ji)
            }

            @* Junction circles (colored ring) *@
            @for (int ji = 0; ji < _layout.Junctions.Count; ji++)
            {
                var j = _layout.Junctions[ji];
                var color = PairColor(ji, _layout.Junctions.Count);
                <g>
                    <circle cx="@F(j.X)" cy="@F(j.Y)" r="@F(GraphLayout.JunctionR)"
                            fill="#0a0a18" stroke="@color" stroke-width="2.5" />
                    <text x="@F(j.X)" y="@F(j.Y + 4)" text-anchor="middle"
                          font-size="13" font-weight="700" fill="@color"
                          font-family="Roboto, sans-serif">+</text>
                    <title>@($"{j.Mat1.Name} + {j.Mat2.Name} = {j.Result.Name}")</title>
                </g>
            }

            @* Card nodes *@
            @foreach (var node in _layout.Nodes)
            {
                var (fill, stroke, strokeW) = NodeStyle(node.Role);
                var imgX = node.X + (GraphLayout.NodeW - 80) / 2;
                var imgY = node.Y + 6;

                <g>
                    <rect x="@F(node.X)" y="@F(node.Y)"
                          width="@F(GraphLayout.NodeW)" height="@F(GraphLayout.NodeH)"
                          rx="6" ry="6"
                          fill="@fill" stroke="@stroke" stroke-width="@strokeW" />

                    @if (node.Card?.ThumbnailDataUrl != null)
                    {
                        <image href="@node.Card.ThumbnailDataUrl"
                               x="@F(imgX)" y="@F(imgY)" width="80" height="64"
                               preserveAspectRatio="xMidYMid meet"
                               style="image-rendering:pixelated;" />
                    }
                    else
                    {
                        <rect x="@F(imgX)" y="@F(imgY)" width="80" height="64"
                              fill="#222" stroke="#444" />
                    }

                    <text x="@F(node.X + GraphLayout.NodeW / 2)"
                          y="@F(node.Y + 84)"
                          text-anchor="middle"
                          font-size="10"
                          font-family="Roboto, sans-serif"
                          fill="@TextColor(node.Role)"
                          font-weight="@(node.Role == NodeRole.Final ? "700" : "500")">
                        @Truncate(node.Name, 20)
                    </text>

                    @if (node.Card != null)
                    {
                        <g>
                            <text x="@F(node.X + GraphLayout.NodeW / 2)"
                                  y="@F(node.Y + 100)"
                                  text-anchor="middle"
                                  font-size="9"
                                  font-family="Roboto, sans-serif"
                                  fill="#888">
                                <tspan fill="#c8a415" font-weight="700">@node.Card.Attack</tspan>
                                <tspan fill="#666"> / </tspan>
                                <tspan fill="#64b5f6" font-weight="700">@node.Card.Defense</tspan>
                            </text>
                        </g>
                    }

                    <title>@($"{node.Name}{(node.Card != null ? $" — ATK {node.Card.Attack} / DEF {node.Card.Defense}" : "")}")</title>
                </g>
            }
        </svg>
    </div>
}

@code {
    [Parameter, EditorRequired] public IEnumerable<FusionSequence> Sequences { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<Card> AllCards { get; set; } = [];

    private GraphLayoutResult? _layout;
    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private static readonly System.Globalization.CultureInfo _inv = System.Globalization.CultureInfo.InvariantCulture;

    protected override void OnParametersSet()
    {
        var byName = new Dictionary<string, Card>();
        foreach (var c in AllCards) byName.TryAdd(c.Name, c);
        _layout = GraphLayout.Build(Sequences, byName);
    }

    private static string F(double v) => v.ToString("0.##", _inv);

    private RenderFragment DrawCurve(double sx, double sy, double tx, double ty,
        string color, string width, bool arrow, int junctionIndex = 0) => __builder =>
    {
        // Vertical S-curve: control points share x with endpoints, y at midline
        double cy = (sy + ty) / 2;
        double endY = arrow ? ty - 6 : ty;
        var d = $"M {F(sx)} {F(sy)} C {F(sx)} {F(cy)}, {F(tx)} {F(cy)}, {F(tx)} {F(endY)}";
        __builder.OpenElement(0, "path");
        __builder.AddAttribute(1, "d", d);
        __builder.AddAttribute(2, "fill", "none");
        __builder.AddAttribute(3, "stroke", color);
        __builder.AddAttribute(4, "stroke-width", width);
        __builder.AddAttribute(5, "opacity", "0.9");
        __builder.AddAttribute(6, "stroke-linecap", "round");
        if (arrow) __builder.AddAttribute(7, "marker-end", $"url(#arrow_{_id}_{junctionIndex})");
        __builder.CloseElement();
    };

    private static string PairColor(int index, int total)
    {
        // Spread hues evenly around the wheel; use a golden-angle offset for nicer separation.
        double hue = (index * 137.508) % 360;
        return $"hsl({hue.ToString("0.##", _inv)}, 65%, 60%)";
    }

    private static (string Fill, string Stroke, string StrokeWidth) NodeStyle(NodeRole role) =>
        role switch
        {
            NodeRole.Final        => ("#2a1a00", "#c8a415", "2"),
            NodeRole.Intermediate => ("#1a1035", "#6a3aae", "1.5"),
            _                     => ("#141428", "#2a5a8e", "1"),
        };

    private static string TextColor(NodeRole role) =>
        role switch
        {
            NodeRole.Final        => "#c8a415",
            NodeRole.Intermediate => "#c0a0ff",
            _                     => "#e0e0e0",
        };

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..(max - 1)] + "…";
}
