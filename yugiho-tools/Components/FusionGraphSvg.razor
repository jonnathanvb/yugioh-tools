@using yugiho_tools.Application.DTOs
@using yugiho_tools.Application.Helpers
@using yugiho_tools.Application.Services
@using yugiho_tools.Domain.Entities
@inject CurrentModContext ModContext

@if (_layout != null)
{
    <div style="width:100%; max-height:75vh; overflow:auto;
                background:#0a0a18; border-radius:6px; padding:8px;">
        <svg xmlns="http://www.w3.org/2000/svg"
             width="@F(_layout.Width * Zoom)"
             height="@F(_layout.Height * Zoom)"
             viewBox="0 0 @F(_layout.Width) @F(_layout.Height)"
             style="display:block;">

            <defs>
                @for (int ji = 0; ji < _layout.Junctions.Count; ji++)
                {
                    var color = PairColor(ji, _layout.Junctions.Count);
                    <marker id="@($"arrow_{_id}_{ji}")" viewBox="0 0 10 10" refX="9" refY="5"
                            markerWidth="6" markerHeight="6" orient="auto-start-reverse">
                        <path d="M0,0 L10,5 L0,10 Z" fill="@color" />
                    </marker>
                }
            </defs>

            @* Material → Junction edges (entrada na borda da carta voltada para a junção) *@
            @for (int ji = 0; ji < _layout.Junctions.Count; ji++)
            {
                var j = _layout.Junctions[ji];
                var color = PairColor(ji, _layout.Junctions.Count);
                var op = JunctionOpacity(ji);
                @DrawCurve(j.Mat1.X + GraphLayout.NodeW / 2, MaterialAnchorY(j.Mat1, j.Y),
                           j.X, j.Y, color, "2", false, op: op)
                @DrawCurve(j.Mat2.X + GraphLayout.NodeW / 2, MaterialAnchorY(j.Mat2, j.Y),
                           j.X, j.Y, color, "2", false, op: op)
            }

            @* Junction → Result edges (with arrow). Entrada na borda do
               resultado voltada para a junção. *@
            @for (int ji = 0; ji < _layout.Junctions.Count; ji++)
            {
                var j = _layout.Junctions[ji];
                var color = PairColor(ji, _layout.Junctions.Count);
                var op = JunctionOpacity(ji);
                @DrawCurve(j.X, j.Y,
                           j.Result.X + GraphLayout.NodeW / 2, ResultAnchorY(j.Result, j.Y),
                           color, "2.5", true, ji, op)
            }

            @* Card nodes — full card image from CDN, click opens detail *@
            @foreach (var node in _layout.Nodes)
            {
                var (_, stroke, strokeW) = NodeStyle(node.Role);
                var op = NodeOpacity(node.Name);
                var card = node.Card;

                <g opacity="@F(op)"
                   style="cursor:pointer;"
                   @onclick="@(() => OnCardClickedInternal(card))"
                   @onmousedown="@(() => StartCardLongPress(card))"
                   @onmouseup="CancelCardLongPress"
                   @onmouseleave="CancelCardLongPress"
                   @ontouchstart="@(() => StartCardLongPress(card))"
                   @ontouchend="CancelCardLongPress"
                   @ontouchcancel="CancelCardLongPress">
                    @if (card != null)
                    {
                        <image href="@CardImage.Url(ModContext.ImageUrlTemplate, card.CardId)"
                               x="@F(node.X)" y="@F(node.Y)"
                               width="@F(GraphLayout.NodeW)" height="@F(GraphLayout.NodeH)"
                               preserveAspectRatio="xMidYMid meet" />
                    }
                    else
                    {
                        <rect x="@F(node.X)" y="@F(node.Y)"
                              width="@F(GraphLayout.NodeW)" height="@F(GraphLayout.NodeH)"
                              rx="6" ry="6" fill="#141428" />
                    }

                    <rect x="@F(node.X)" y="@F(node.Y)"
                          width="@F(GraphLayout.NodeW)" height="@F(GraphLayout.NodeH)"
                          rx="6" ry="6"
                          fill="none" stroke="@stroke" stroke-width="@strokeW" />

                    <title>@($"{node.Name}{(card != null ? $" — ATK {card.Attack} / DEF {card.Defense}" : "")}")</title>
                </g>
            }

            @* Junction circles *@
            @for (int ji = 0; ji < _layout.Junctions.Count; ji++)
            {
                var j = _layout.Junctions[ji];
                var color = PairColor(ji, _layout.Junctions.Count);
                var op = JunctionOpacity(ji);
                var idx = ji;

                <g opacity="@F(op)"
                   style="cursor:pointer;"
                   @onmouseover="() => OnJunctionEnter(idx)"
                   @onmouseout="OnJunctionLeave"
                   @onclick="@(() => OnJunctionClickedInternal(j))">
                    <circle cx="@F(j.X)" cy="@F(j.Y)" r="@F(GraphLayout.JunctionR + 6)"
                            fill="transparent" />
                    <circle cx="@F(j.X)" cy="@F(j.Y)" r="@F(GraphLayout.JunctionR)"
                            fill="#0a0a18" stroke="@color" stroke-width="2.5" />
                    <text x="@F(j.X)" y="@F(j.Y + 9)" text-anchor="middle"
                          font-size="24" font-weight="800" fill="@color"
                          font-family="Roboto, sans-serif"
                          style="pointer-events:none;">@j.Step</text>
                    <title>@($"Etapa {j.Step}: {j.Mat1.Name} + {j.Mat2.Name} = {j.Result.Name}")</title>
                </g>
            }
        </svg>
    </div>
}

@code {
    [Parameter, EditorRequired] public IEnumerable<FusionSequence> Sequences { get; set; } = [];
    [Parameter, EditorRequired] public IReadOnlyList<Card> AllCards { get; set; } = [];
    [Parameter] public double Zoom { get; set; } = 1.0;
    /// <summary>Single click on a card.</summary>
    [Parameter] public EventCallback<Card> OnCardClicked { get; set; }
    /// <summary>Long press (3s) on a card.</summary>
    [Parameter] public EventCallback<Card> OnCardLongClicked { get; set; }
    /// <summary>If set, fusions whose result requires more than N steps are dropped.</summary>
    [Parameter] public int? MaxSteps { get; set; }
    /// <summary>Click on a junction (the numbered "+" node).</summary>
    [Parameter] public EventCallback<JunctionNode> OnJunctionClicked { get; set; }
    /// <summary>Modo de layout: Fusão ou Step.</summary>
    [Parameter] public GraphLayoutMode LayoutMode { get; set; } = GraphLayoutMode.Fusion;
    /// <summary>Visibilidade: todas as fusões ou versão simplificada (greedy step-DESC).</summary>
    [Parameter] public GraphVisibility Visibility { get; set; } = GraphVisibility.All;

    private GraphLayoutResult? _layout;
    private readonly string _id = Guid.NewGuid().ToString("N")[..8];
    private static readonly System.Globalization.CultureInfo _inv = System.Globalization.CultureInfo.InvariantCulture;

    private int? _hoveredJunctionIndex;
    private HashSet<int> _highlightedJunctions = [];
    private HashSet<string> _highlightedNodes = [];

    private const double FadedOpacity = 0.15;

    protected override void OnParametersSet()
    {
        var byName = new Dictionary<string, Card>();
        foreach (var c in AllCards) byName.TryAdd(c.Name, c);
        _layout = GraphLayout.Build(Sequences, byName, MaxSteps, LayoutMode, Visibility);

        _hoveredJunctionIndex = null;
        _highlightedJunctions = [];
        _highlightedNodes = [];
    }

    // ── Click vs long-press handling ────────────────────────────
    private CancellationTokenSource? _cardPressCts;
    private bool _cardLongFired;
    private const int CardLongPressMs = 3000;

    private async Task StartCardLongPress(Card? card)
    {
        if (card is null) return;
        CancelCardLongPress();
        _cardLongFired = false;
        _cardPressCts = new CancellationTokenSource();
        var token = _cardPressCts.Token;
        try
        {
            await Task.Delay(CardLongPressMs, token);
            _cardLongFired = true;
            if (OnCardLongClicked.HasDelegate)
                await OnCardLongClicked.InvokeAsync(card);
        }
        catch (TaskCanceledException) { }
        catch (OperationCanceledException) { }
    }

    private void CancelCardLongPress()
    {
        _cardPressCts?.Cancel();
        _cardPressCts?.Dispose();
        _cardPressCts = null;
    }

    private async Task OnCardClickedInternal(Card? card)
    {
        // Suppress click if long-press fired
        if (_cardLongFired) { _cardLongFired = false; return; }
        if (card is null) return;
        if (OnCardClicked.HasDelegate)
            await OnCardClicked.InvokeAsync(card);
    }

    private async Task OnJunctionClickedInternal(JunctionNode junction)
    {
        if (OnJunctionClicked.HasDelegate)
            await OnJunctionClicked.InvokeAsync(junction);
    }

    private void OnJunctionEnter(int idx)
    {
        if (_layout is null || idx < 0 || idx >= _layout.Junctions.Count) return;

        var producers = new Dictionary<string, List<int>>();
        for (int i = 0; i < _layout.Junctions.Count; i++)
        {
            var key = _layout.Junctions[i].Result.Name;
            if (!producers.TryGetValue(key, out var list))
                producers[key] = list = [];
            list.Add(i);
        }

        var jset = new HashSet<int> { idx };
        var nset = new HashSet<string>();
        var stack = new Stack<int>();
        stack.Push(idx);

        while (stack.Count > 0)
        {
            var ji = stack.Pop();
            var j = _layout.Junctions[ji];
            nset.Add(j.Result.Name);
            nset.Add(j.Mat1.Name);
            nset.Add(j.Mat2.Name);

            foreach (var matName in new[] { j.Mat1.Name, j.Mat2.Name })
            {
                if (producers.TryGetValue(matName, out var prodList))
                    foreach (var pi in prodList)
                        if (jset.Add(pi)) stack.Push(pi);
            }
        }

        _hoveredJunctionIndex = idx;
        _highlightedJunctions = jset;
        _highlightedNodes = nset;
    }

    private void OnJunctionLeave()
    {
        _hoveredJunctionIndex = null;
        _highlightedJunctions = [];
        _highlightedNodes = [];
    }

    private double NodeOpacity(string name) =>
        _hoveredJunctionIndex is null ? 1.0
        : _highlightedNodes.Contains(name) ? 1.0 : FadedOpacity;

    private double JunctionOpacity(int idx) =>
        _hoveredJunctionIndex is null ? 1.0
        : _highlightedJunctions.Contains(idx) ? 1.0 : FadedOpacity;

    private static string F(double v) => v.ToString("0.##", _inv);

    private RenderFragment DrawCurve(double sx, double sy, double tx, double ty,
        string color, string width, bool arrow, int junctionIndex = 0,
        double op = 1.0) => __builder =>
    {
        double cy = (sy + ty) / 2;
        // Recua a ponta 6px no sentido oposto à direção do path para o
        // marker da seta caber sem invadir a carta.
        double endY = arrow ? ty - Math.Sign(ty - sy) * 6 : ty;
        var d = $"M {F(sx)} {F(sy)} C {F(sx)} {F(cy)}, {F(tx)} {F(cy)}, {F(tx)} {F(endY)}";
        __builder.OpenElement(0, "path");
        __builder.AddAttribute(1, "d", d);
        __builder.AddAttribute(2, "fill", "none");
        __builder.AddAttribute(3, "stroke", color);
        __builder.AddAttribute(4, "stroke-width", width);
        __builder.AddAttribute(5, "opacity", F(0.9 * op));
        __builder.AddAttribute(6, "stroke-linecap", "round");
        if (arrow) __builder.AddAttribute(7, "marker-end", $"url(#arrow_{_id}_{junctionIndex})");
        __builder.CloseElement();
    };

    // Retorna a Y da borda da carta voltada para a junção (topo se a junção
    // está acima da carta; base se está abaixo). Permite que ATK ↓ desenhe
    // bem mesmo com resultado acima dos materiais.
    private static double MaterialAnchorY(GraphNode m, double junctionY) =>
        junctionY > m.Y + GraphLayout.NodeH / 2
            ? m.Y + GraphLayout.NodeH   // junção abaixo → ancoragem na base
            : m.Y;                       // junção acima  → ancoragem no topo

    private static double ResultAnchorY(GraphNode r, double junctionY) =>
        junctionY < r.Y + GraphLayout.NodeH / 2
            ? r.Y                        // junção acima  → entrada pelo topo
            : r.Y + GraphLayout.NodeH;   // junção abaixo → entrada pela base

    private static string PairColor(int index, int total)
    {
        double hue = (index * 137.508) % 360;
        return $"hsl({hue.ToString("0.##", _inv)}, 65%, 60%)";
    }

    private static (string Fill, string Stroke, string StrokeWidth) NodeStyle(NodeRole role) =>
        role switch
        {
            NodeRole.Final        => ("#2a1a00", "#c8a415", "3"),
            NodeRole.Intermediate => ("#1a1035", "#6a3aae", "2.5"),
            _                     => ("#141428", "#2a5a8e", "2"),
        };
}
