@using yugiho_tools.Application.Helpers
@using yugiho_tools.Application.Services
@using yugiho_tools.Domain.Entities

@using Color = MudBlazor.Color
@using Size  = MudBlazor.Size

@inject CurrentModContext ModContext
@inject LocalizationService L
@implements IDisposable

@*
    Reusable card grid with filter bar (search, type, attribute, ATK/DEF range,
    sort, "fusion-only" toggle). Used by Home (fusion picker) and Cards (browser).

    Behaviors:
      • Short click  → OnCardClick   (selecting / opening detail)
      • Long press   → OnCardLongPress (3s, opens detail dialog upstream)
      • Selected set is optional — pass HighlightSelected for the deck-builder use.
*@

<MudPaper Class="pa-4 mb-4" Elevation="3"
          Style="background:#141428; border:1px solid #2a2a6e;">

    <div class="d-flex align-center justify-space-between mb-3 flex-wrap gap-2">
        <MudButton Variant="Variant.Text" Size="Size.Medium"
                   StartIcon="@(IsExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                   OnClick="ToggleExpanded"
                   Style="color:#c8a415; font-weight:700; letter-spacing:1px;">
            <MudIcon Icon="@Icons.Material.Filled.GridView" Class="mr-1" />
            @Title
        </MudButton>

        @if (ShowZoom)
        {
            <div class="d-flex align-center gap-1" title="@L.T("catalog.zoomTitle")">
                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                               Size="Size.Small"
                               OnClick="ZoomOut"
                               Disabled="@(_zoom <= ZoomMin)" />
                <MudText Style="min-width:42px; text-align:center; color:#c8a415; font-size:0.85rem;">
                    @($"{(int)Math.Round(_zoom * 100)}%")
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Add"
                               Size="Size.Small"
                               OnClick="ZoomIn"
                               Disabled="@(_zoom >= ZoomMax)" />
            </div>
        }
    </div>

    <MudCollapse Expanded="@IsExpanded">
        <MudGrid Spacing="2" Class="mb-2">
            <MudItem xs="12" sm="6" md="4">
                <MudTextField T="string"
                              Value="@_searchTerm"
                              ValueChanged="@(v => { _searchTerm = v ?? ""; })"
                              Immediate="true"
                              Label="@L.T("catalog.searchPlaceholder")"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search" />
            </MudItem>
            
            <MudItem xs="6" sm="4" md="2">
                <RangeFilterField Label="ATK"
                                  Min="_minAtk" MinChanged="@(v => _minAtk = v)"
                                  Max="_maxAtk" MaxChanged="@(v => _maxAtk = v)" />
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <RangeFilterField Label="DEF"
                                  Min="_minDef" MinChanged="@(v => _minDef = v)"
                                  Max="_maxDef" MaxChanged="@(v => _maxDef = v)" />
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="2" Class="mb-3">
            <MudItem xs="6" sm="3" md="2">
                <CategoryFilterSelect Kind="CategoryIconLabel.CategoryKind.Type"
                                      Label="@L.T("common.type")"
                                      Value="_filterType"
                                      ValueChanged="@(v => _filterType = v)" />
            </MudItem>
            <MudItem xs="6" sm="3" md="2">
                <CategoryFilterSelect Kind="CategoryIconLabel.CategoryKind.Attribute"
                                      Label="@L.T("common.attribute")"
                                      Value="_filterAttribute"
                                      ValueChanged="@(v => _filterAttribute = v)" />
            </MudItem>
            <MudItem xs="6" sm="3" md="2">
                <MudSelect T="CardSortMode" @bind-Value="_sortMode"
                           Label="@L.T("catalog.sort")" Variant="Variant.Outlined">
                    <MudSelectItem T="CardSortMode" Value="CardSortMode.Default">@L.T("catalog.sort.default")</MudSelectItem>
                    <MudSelectItem T="CardSortMode" Value="CardSortMode.AtkDesc">@L.T("catalog.sort.atkDesc")</MudSelectItem>
                    <MudSelectItem T="CardSortMode" Value="CardSortMode.AtkAsc">@L.T("catalog.sort.atkAsc")</MudSelectItem>
                    <MudSelectItem T="CardSortMode" Value="CardSortMode.DefDesc">@L.T("catalog.sort.defDesc")</MudSelectItem>
                    <MudSelectItem T="CardSortMode" Value="CardSortMode.DefAsc">@L.T("catalog.sort.defAsc")</MudSelectItem>
                    <MudSelectItem T="CardSortMode" Value="CardSortMode.Type">@L.T("catalog.sort.type")</MudSelectItem>
                </MudSelect>
            </MudItem>
            @if (FusionMaterialIds is not null)
            {
                <MudItem xs="12" md="3" Class="d-flex align-center">
                    <MudSwitch T="bool" @bind-Value="_onlyFusionMaterials"
                               Color="Color.Primary"
                               Label="@L.T("catalog.onlyFusionMaterials")" />
                </MudItem>
            }
        </MudGrid>

        @{
            var filtered = FilteredCards().Take(MaxGridCards).ToList();
            var totalFiltered = FilteredCardsTotal();
            int tileMinPx = (int)(80  * _zoom);
            int tileMaxPx = (int)(110 * _zoom);
        }
        <MudText Typo="Typo.caption" Style="color:#888;" Class="mb-2">
            @(totalFiltered > MaxGridCards
                ? L.T("catalog.totalCountTruncated", filtered.Count, totalFiltered, MaxGridCards)
                : L.T("catalog.totalCount", filtered.Count, totalFiltered))
        </MudText>

        <div class="card-grid"
             style="@($"--tile-min:{tileMinPx}px; --tile-max:{tileMaxPx}px;")">
            @foreach (var c in filtered)
            {
                bool selected = HighlightSelected?.Invoke(c) ?? false;
                var card = c;
                <div class="card-tile @(selected ? "selected" : "")"
                     @onclick="() => InvokeClick(card)"
                     title="@($"{c.Name} — ATK {c.Attack} / DEF {c.Defense}")">
                    <CardCover Card="@c" Fill="true" ImgClass="card-tile-img" />
                    @if (selected)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                 Class="card-tile-check" />
                    }
                </div>
            }
        </div>
    </MudCollapse>
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "Catálogo de cartas";
    [Parameter, EditorRequired] public IReadOnlyList<Card> Cards { get; set; } = [];
    [Parameter] public EventCallback<Card> OnCardClick { get; set; }
    [Parameter] public Func<Card, bool>? HighlightSelected { get; set; }
    [Parameter] public HashSet<int>? FusionMaterialIds { get; set; }
    [Parameter] public bool ShowZoom { get; set; } = true;
    [Parameter] public int  MaxGridCards { get; set; } = 200;
    [Parameter] public bool StartExpanded { get; set; } = true;

    /// <summary>Two-way: estado expandido/colapsado controlável pelo
    /// pai. Quando o caller liga via <c>@bind-Expanded</c>, ele pode
    /// fechar o catálogo programaticamente (ex.: depois de um scan
    /// pra dar foco no resultado). Sem binding, o componente usa
    /// estado interno e o pai não interfere.</summary>
    [Parameter] public bool? Expanded { get; set; }
    [Parameter] public EventCallback<bool> ExpandedChanged { get; set; }

    public enum CardSortMode { Default, AtkDesc, AtkAsc, DefDesc, DefAsc, Type }

    private string _searchTerm = "";
    private int?   _filterType;
    private int?   _filterAttribute;
    private int?   _minAtk, _maxAtk, _minDef, _maxDef;
    private bool   _onlyFusionMaterials;
    private CardSortMode _sortMode = CardSortMode.Default;
    private bool _internalExpanded;
    private bool IsExpanded => Expanded ?? _internalExpanded;
    private double _zoom = 1.0;
    private const double ZoomMin = 0.5, ZoomMax = 2.0, ZoomStep = 0.1;

    protected override void OnParametersSet()
    {
        // Estado interno preserva StartExpanded inicialmente; updates do
        // pai via Expanded (binding) têm precedência via IsExpanded.
        _internalExpanded = StartExpanded || _internalExpanded;
    }

    private async Task ToggleExpanded()
    {
        var next = !IsExpanded;
        if (Expanded.HasValue) await ExpandedChanged.InvokeAsync(next);
        else _internalExpanded = next;
    }

    protected override void OnInitialized()
    {
        L.Changed += OnLocaleChanged;
    }

    private void OnLocaleChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => L.Changed -= OnLocaleChanged;

    private void ZoomIn()  => _zoom = Math.Min(ZoomMax, Math.Round(_zoom + ZoomStep, 2));
    private void ZoomOut() => _zoom = Math.Max(ZoomMin, Math.Round(_zoom - ZoomStep, 2));

    private IEnumerable<Card> FilteredCards()
    {
        var query = Cards.Where(c => !string.IsNullOrWhiteSpace(c.Name));

        if (!string.IsNullOrEmpty(_searchTerm))
        {
            var term = _searchTerm.Trim();
            query = query.Where(c =>
                c.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                (!string.IsNullOrEmpty(c.Description) &&
                 c.Description.Contains(term, StringComparison.OrdinalIgnoreCase)) ||
                c.CardId.ToString().Contains(term));
        }

        if (_minAtk.HasValue) query = query.Where(c => c.Attack  >= _minAtk.Value);
        if (_maxAtk.HasValue) query = query.Where(c => c.Attack  <= _maxAtk.Value);
        if (_minDef.HasValue) query = query.Where(c => c.Defense >= _minDef.Value);
        if (_maxDef.HasValue) query = query.Where(c => c.Defense <= _maxDef.Value);
        if (_filterType.HasValue)      query = query.Where(c => c.CardType  == _filterType.Value);
        if (_filterAttribute.HasValue) query = query.Where(c => c.Attribute == _filterAttribute.Value);

        if (_onlyFusionMaterials && FusionMaterialIds is not null)
            query = query.Where(c => FusionMaterialIds.Contains(c.CardId - 1));

        query = _sortMode switch
        {
            CardSortMode.AtkDesc => query.OrderByDescending(c => c.Attack).ThenBy(c => c.Name),
            CardSortMode.AtkAsc  => query.OrderBy(c => c.Attack).ThenBy(c => c.Name),
            CardSortMode.DefDesc => query.OrderByDescending(c => c.Defense).ThenBy(c => c.Name),
            CardSortMode.DefAsc  => query.OrderBy(c => c.Defense).ThenBy(c => c.Name),
            CardSortMode.Type    => query.OrderBy(c => c.CardType).ThenBy(c => c.Name),
            _                    => query.OrderBy(c => c.CardId),
        };

        return query;
    }

    private int FilteredCardsTotal() => FilteredCards().Count();

    private async Task InvokeClick(Card c)
    {
        if (OnCardClick.HasDelegate) await OnCardClick.InvokeAsync(c);
    }
}
