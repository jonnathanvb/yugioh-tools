<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <!-- See https://aka.ms/maui-publish-app-store#add-entitlements for more information about adding entitlements.-->
    <dict>
        <!-- App Sandbox DESABILITADO: a captura de tela via CGWindowListCreateImage
             em outras janelas (ex.: ePSXe) requer acesso fora do sandbox. Para
             distribuir via Mac App Store seria necessário usar ScreenCaptureKit
             com user-consent dialog explícito. -->
        <key>com.apple.security.app-sandbox</key>
        <false/>
        <!-- Necessário pra UpdateService ler GitHub Releases (no-op no Mac, mas
             mantido caso o usuário implemente Sparkle no futuro). -->
        <key>com.apple.security.network.client</key>
        <true/>
    </dict>
</plist>
